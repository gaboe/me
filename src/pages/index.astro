  {
    name: "Coinwage",
    title: "CTO, Co-Founder",
    period: "Jan 2022 - Jan 2026",
    note: "Ended on Jan 1, 2026",
    summary:
      "Co-founder and CTO role in a product around compensation and crypto. The project and active executive role are now closed.",
