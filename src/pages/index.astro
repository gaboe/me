];

const strengths = [
  "Product and system architecture",
  "Technical leadership and mentoring",
  "AI agents, automation, and internal tools",
  "Full-stack delivery of production applications",
  "Consulting work with a high level of ownership",
  "Translating business goals into technical decisions",
];

const engagementSignals = [
  "Architecture rescue for products that already have users and complexity",
  "Technical leadership when teams need clearer decisions and delivery shape",
  "AI agents, automation, and internal tools connected to real workflows",
  "Consulting delivery that balances business pressure with system durability",
];

const audienceRoutes = [
  {
    code: "CLIENT",
    title: "Need technical order",
    summary:
      "Use me when the product direction is clear enough to matter, but the engineering system needs structure, ownership, and sharper decisions.",
    action: "Discuss collaboration",
    href: "#kontakt",
  },
  {
    code: "RECRUITER",
    title: "Validate seniority",
    summary:
      "Long-term Blogic trajectory from junior developer to principal consultant, with hands-on delivery and leadership across client work.",
    action: "Read career log",
    href: "#skusenosti",
  },
  {
    code: "FOUNDER",
    title: "Evaluate judgment",
    summary:
      "CTO and co-founder experience, archived precisely, plus practical consulting judgment for ambiguous technical and product decisions.",
    action: "Review operating rules",
    href: "#principles",
  },
];

const principles = [
