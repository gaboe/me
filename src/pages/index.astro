  },
  {
    company: "Blogic",
    role: "Lead Software Consultant",
    period: "Mar 2022 - Jun 2024",
    meta: "Zlin, Czechia",
    summary:
      "Led delivery, coordinated engineering decisions, and took ownership of technical solutions across client projects.",
  },
  {
    company: "Blogic",
    role: "Senior Software Developer",
    period: "Apr 2019 - Mar 2022",
    meta: "Zlin, Czechia",
    summary:
      "Designed and implemented production applications, mentored developers, and moved from individual delivery toward broader responsibility for solution quality.",
  },
  {
    company: "Blogic",
    role: "Software Developer",
    period: "Jun 2017 - Apr 2019",
    meta: "District Zlin, Czech Republic",
    summary:
      "Full-stack development, delivery of client-facing functionality, and the practical foundation for long-term consulting work.",
